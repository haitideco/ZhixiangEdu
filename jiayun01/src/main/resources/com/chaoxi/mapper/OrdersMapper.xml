<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.chaoxi.mapper.OrdersMapper">

    <select id="getAll" resultMap="OrdersMap">
        select o.*,od.* from orders o,order_detail od
        <where>
            <if test="status != null">
                o.status = #{status}
            </if>
            and o.order_id = od.id
        </where>
    </select>

    <resultMap id="OrdersMap" type="com.chaoxi.pojo.Orders">
        <result property="id" column="id"></result>
        <result property="shopId" column="shop_id"></result>
        <result property="shopName" column="shop_name"></result>
        <result property="shopCount" column="shop_count"></result>
        <result property="userId" column="user_id"></result>
        <result property="account" column="account"></result>
        <result property="status" column="status"></result>
        <result property="phone" column="phone"></result>
        <result property="image" column="image"></result>
        <result property="price" column="price"></result>
        <result property="orderId" column="order_id"></result>

        <association property="orderDetail" javaType="com.chaoxi.pojo.OrderDetail">
            <result property="id" column="id"></result>
            <result property="endTime" column="end_time"></result>
            <result property="description" column="description"></result>
            <result property="createTime" column="create_time"></result>
            <result property="updateTime" column="update_time"></result>
            <result property="createUser" column="create_user"></result>
            <result property="updateUser" column="update_user"></result>
        </association>
    </resultMap>
</mapper>