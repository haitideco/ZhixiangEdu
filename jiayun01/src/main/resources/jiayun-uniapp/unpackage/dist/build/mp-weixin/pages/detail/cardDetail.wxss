.card{width:80%;background-size:100%;margin:auto;margin-top:2vh;position:relative;height:25vh}.card image{height:23vh;width:100%;border-radius:2vh;z-index:1;position:absolute}.card text{position:absolute;z-index:2}.card-name{font-size:2.5vh;font-weight:700;color:#2e8b57;position:absolute;top:3.5vh;left:2.5vh}.card-type{font-size:3vh;position:absolute;right:2vh;top:2.5vh;color:#fcf7f3}.card-price{font-size:2vh;color:#f8f8ff;position:absolute;top:17vh;font-weight:700;left:3vh}.goods-carts{display:flex;flex-direction:column;position:fixed;left:0;right:0;bottom:0}.classList{background-color:#fff;margin-top:2vh;padding:2vh}.classList-top{font-size:3vh;font-weight:700}.classList-item{background-color:#fff;margin:1vh 0;height:2vh;line-height:2vh;padding:1vh;list-style:circle}