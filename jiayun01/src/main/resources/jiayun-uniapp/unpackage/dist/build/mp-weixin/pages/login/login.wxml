<view class="login-container"><view class="login-top"><image src="/static/logo.png"></image><view>高合珈云系统登录</view></view><view class="login-form"><view class="login-form-username"><image src="/static/img/login.png"></image><input class="input" type="nickname" data-event-opts="{{[['input',[['__set_model',['$0','phone','$event',[]],['loginForm']]]]]}}" value="{{loginForm.phone}}" bindinput="__e"/></view><view class="login-form-code"><view class="login-form-code-left"><image src="/static/img/code1.png"></image><input class="input" style="margin-left:2vh;" placeholder="请输入验证码" type="text" data-event-opts="{{[['input',[['__set_model',['$0','code','$event',[]],['loginForm']]]]]}}" value="{{loginForm.code}}" bindinput="__e"/></view><block wx:if="{{sendMsg=='获取验证码'}}"><view class="login-code"><button data-event-opts="{{[['tap',[['getCode']]]]}}" bindtap="__e">{{sendMsg}}</button></view></block><block wx:else><view class="login-code"><button>{{sendMsg}}</button></view></block></view><uni-icons vue-id="35a7246c-1" custom-prefix="iconfont" type="icon-xingbienv" size="30" bind:__l="__l"></uni-icons></view><view class="login-button"><button data-event-opts="{{[['tap',[['login']]]]}}" bindtap="__e">登录</button></view><view><uni-popup class="vue-ref" vue-id="35a7246c-2" type="message" data-ref="message" bind:__l="__l" vue-slots="{{['default']}}"><uni-popup-message vue-id="{{('35a7246c-3')+','+('35a7246c-2')}}" type="{{msgType}}" message="{{messageText}}" duration="{{2000}}" bind:__l="__l"></uni-popup-message></uni-popup></view></view>