<view><view class="top"><view class="top-image"><image src="{{userDetail.image}}"></image></view><block wx:if="{{user}}"><view data-event-opts="{{[['tap',[['getUser',['$event']]]]]}}" class="top-loginAndRegist" bindtap="__e"><view>登录/注册</view><view class="top-loginAndRegist-score">积分:0</view></view></block><block wx:else><view data-event-opts="{{[['tap',[['updateUser',['$event']]]]]}}" class="top-loginAndRegist" bindtap="__e"><view>个人信息</view><view class="top-loginAndRegist-score">{{'昵称:'+userDetail.name+''}}</view></view></block><view class="top-code"><image src="/static/img/code.png" mode></image></view></view><view class="nav"><block wx:for="{{navArr}}" wx:for-item="item" wx:for-index="__i0__"><view data-event-opts="{{[['tap',[['turn',['$0'],[[['navArr','',__i0__]]]]]]]}}" class="nav-item" bindtap="__e"><view class="nav-item-count">{{''+item.count+''}}</view><view class="nav-item-text">{{''+item.text+''}}</view></view></block></view><view class="service"><view class="service-title">我的服务</view><block wx:for="{{serviceArr}}" wx:for-item="item" wx:for-index="__i1__"><view data-event-opts="{{[['tap',[['turn',['$0'],[[['serviceArr','',__i1__]]]]]]]}}" class="service-item" bindtap="__e"><view class="service-item-image"><image src="{{item.image}}"></image></view><view class="service-item-text">{{''+item.text+''}}</view></view></block></view><view class="bottom"></view></view>