.box-bg{background-color:#f5f5f5;padding:5px 0}.city{display:flex;flex-direction:row;align-items:center;justify-content:flex-start;margin-left:4px}.input-view{display:flex;flex-direction:row;flex:1;background-color:#f8f8f8;height:$nav-height;border-radius:15px;padding:0 15px;flex-wrap:nowrap;margin:7px 0;line-height:$nav-height}.input-uni-icon{line-height:$nav-height}.nav-bar-input{height:$nav-height;line-height:$nav-height;padding:0 5px;font-size:12px;background-color:#f8f8f8}.orders{display:flex;flex-wrap:wrap}.orders-item{background-color:#fff;width:95%;margin:1vh auto;border-radius:2vh}.orders-item-top{width:100%;flex:3;display:flex;height:12vh}.orders-item-bottom{flex:1;width:100%;display:flex;justify-content:flex-end;margin:2vh}.orders-item-top-image{flex:0 0 12vh;height:auto;margin-top:1.5vh;margin-left:1.5vh}.orders-item-top-image image{width:100%;height:100%;border-radius:2vh}.orders-item-top-main-item{display:flex;justify-content:space-around;margin-top:1vh}.orders-item-top-main{margin:1vh 1.2vh;flex:1;display:flex;flex-direction:column}.orders-item-top-main-item-shopName{flex:4;overflow:hidden;text-overflow:ellipsis;-webkit-line-clamp:1;display:-webkit-box;-webkit-box-orient:vertical}.orders-item-top-main-item-account{flex:1;text-align:center}.orders-item-top-main-item-description{font-size:2vh;color:grey;width:100%;flex:2;margin-top:1vh}.orders-item-bottom-deleteOrders{border:.2vh solid grey;padding:1vh 1.5vh;border-radius:4vh;margin-right:2vh;font-size:1.5vh}.orders-item-bottom-moreOrders{border:.2vh solid grey;padding:1vh 1.5vh;border-radius:4vh;margin-right:2vh;font-size:1.5vh;font-weight:700;color:orange;border:.2vh solid orange}