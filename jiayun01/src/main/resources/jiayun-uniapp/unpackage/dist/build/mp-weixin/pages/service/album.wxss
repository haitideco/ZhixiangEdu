.content{display:flex;justify-content:center;flex-wrap:wrap}.album-item{display:flex;margin:3vh auto;width:100%;position:relative}.album-item image{border-radius:3vh}.album-item text{position:absolute}.album-item-count{position:absolute;height:3vh;background-color:#435963;border-radius:5vh;width:9vh;padding-left:1.5vh;box-sizing:initial;padding-top:.5vh;top:10%;right:3vh;z-index:2;color:#fff}.album-item-count-text{top:10%;right:1.8vh;font-size:2vh}.album-item-title{background-color:#fff;width:14vh;text-align:center;border-radius:3vh;color:#000;font-weight:700;top:80%;left:2vh}