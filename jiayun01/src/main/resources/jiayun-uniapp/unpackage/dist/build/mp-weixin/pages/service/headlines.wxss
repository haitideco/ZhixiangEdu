.container{display:flex;justify-content:center;width:100%}.headlines{width:90%}.headlines-item{display:flex;position:relative;background-color:#fff;border-radius:2vh;height:20vh;width:100%;margin-top:4vh;white-space:normal;overflow:hidden;text-overflow:ellipsis}.headlines-item-title{color:#cd5c5c;display:flex;position:absolute;flex-wrap:wrap;width:18vh;font-weight:700;top:2vh;left:2vh}.headline-item-description{display:flex;position:absolute;flex-wrap:nowrap;width:19vh;height:8vh;font-size:1.5vh;top:10vh;left:2vh}.headlines-item image{position:absolute;width:20vh;height:13vh;top:3.5vh;right:3vh;border-radius:2vh}