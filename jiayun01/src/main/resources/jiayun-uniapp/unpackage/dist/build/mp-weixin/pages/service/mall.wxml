<view class="container"><view class="banner"><text class="banner-title">女神新宠岂止于好</text><text class="banner-description">瑜伽课程包</text><view class="banner-activity">立即开抢 ></view></view><view class="service"><block wx:for="{{services}}" wx:for-item="item" wx:for-index="__i0__"><view class="service-item"><image src="{{item.imgSrc}}"></image><view>{{item.text}}</view></view></block></view><view class="shop"><view></view><view class="shop-content"><view class="shop-content-nav"><block wx:for="{{categoryList}}" wx:for-item="item" wx:for-index="__i1__"><view data-event-opts="{{[['tap',[['initShop',['$0'],[[['categoryList','',__i1__,'id']]]]]]]}}" class="{{['shop-content-nav-item',asideClassActive]}}" bindtap="__e">{{''+item.name+''}}</view></block></view><view class="shop-content-shop"><block wx:if="{{shopList!=null}}"><view><block wx:for="{{shopList}}" wx:for-item="item" wx:for-index="__i2__"><view data-event-opts="{{[['tap',[['shopDetail',['$0'],[[['shopList','',__i2__]]]]]]]}}" class="shop-content-shop-item" bindtap="__e"><view class="shop-content-shop-item-image"><image src="{{item.image}}"></image></view><view class="shop-content-shop-item-right"><view class="shop-content-shop-item-shopName">{{''+item.shopName+''}}</view><view class="shop-content-shop-item-description">{{''+item.description+''}}</view><view class="shop-content-shop-item-price"><view class="shop-content-shop-item-oldPrice"><block wx:if="{{item.oldPrice!=null}}"><view>{{''+item.oldPrice+'¥'}}</view></block><block wx:else><view class="shop-content-shop-item-oldPrice">最新价</view></block></view><view class="shop-content-shop-item-newPrice">{{''+item.newPrice+'¥'}}<block wx:if="{{item.status==1}}"><view class="shop-content-shop-item-buy">购买</view></block><block wx:else><view class="shop-content-shop-item-disBuyed">停售</view></block></view></view></view></view></block></view></block></view></view></view></view>