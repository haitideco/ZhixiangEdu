<view class="card-detail-container"><view class="header-section"><view class="header-bg"></view><view class="header-content"><view data-event-opts="{{[['tap',[['back',['$event']]]]]}}" class="back-btn" bindtap="__e"><text class="back-icon">‹</text></view><text class="header-title">卡片详情</text></view></view><view class="main-content"><view class="card-preview"><image class="card-image" src="{{cardDetail.image}}" mode="aspectFill"></image><view class="card-overlay"><view class="card-badge">{{cardDetail.type}}</view><text class="card-name">{{cardDetail.name}}</text><view class="card-price-row"><text class="price-symbol">¥</text><text class="price-value">{{cardDetail.price}}</text></view></view></view><view class="info-section"><view class="section-header"><view class="section-title"><text class="title-text">卡片信息</text><view class="title-line"></view></view></view><view class="info-list"><view class="info-item"><text class="info-label">有效天数</text><text class="info-value">{{cardDetail.day+" 天"}}</text></view><view class="info-item"><text class="info-label">卡片状态</text><view class="{{['status-tag',(cardDetail.status=='在售')?'active':'']}}">{{''+cardDetail.status+''}}</view></view><view class="info-item full-width"><text class="info-label">卡片描述</text><text class="info-desc">{{cardDetail.description||'暂无描述'}}</text></view></view></view><block wx:if="{{$root.g0>0}}"><view class="course-section"><view class="section-header"><view class="section-title"><text class="title-text">支持课程</text><view class="title-line"></view></view><text class="course-count">{{"共"+$root.g1+"门课程"}}</text></view><view class="course-list"><block wx:for="{{classList}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="course-item"><view class="course-index">{{index+1}}</view><text class="course-name">{{item}}</text></view></block></view></view></block></view><block wx:if="{{status==''}}"><view class="bottom-bar"><view data-event-opts="{{[['tap',[['showAdmin',['$event']]]]]}}" class="consult-btn" bindtap="__e"><image class="btn-icon" src="/static/img/telephone.png"></image><text>咨询</text></view><view data-event-opts="{{[['tap',[['buttonClick',['$event']]]]]}}" class="buy-btn" bindtap="__e"><text>立即购买</text></view></view></block><uni-popup class="vue-ref" vue-id="32de9e70-1" background-color="transparent" data-ref="popup" bind:__l="__l" vue-slots="{{['default']}}"><view class="popup-container"><view class="popup-header"><text class="popup-title">选择支付方式</text><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" class="popup-close" bindtap="__e">×</view></view><view class="popup-content"><view data-event-opts="{{[['tap',[['pageToPay',['$event']]]]]}}" class="pay-option" bindtap="__e"><image class="pay-icon" src="/static/img/wx.png"></image><text class="pay-name">微信支付</text><text class="pay-arrow">›</text></view><view data-event-opts="{{[['tap',[['showAdmin',['$event']]]]]}}" class="pay-option" bindtap="__e"><image class="pay-icon" src="/static/img/telephone.png"></image><text class="pay-name">联系管理员</text><text class="pay-arrow">›</text></view></view></view></uni-popup><uni-popup class="vue-ref" vue-id="32de9e70-2" background-color="transparent" data-ref="adminList" bind:__l="__l" vue-slots="{{['default']}}"><view class="popup-container"><view class="popup-header"><text class="popup-title">联系管理员</text><view data-event-opts="{{[['tap',[['e1',['$event']]]]]}}" class="popup-close" bindtap="__e">×</view></view><view class="popup-content"><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view data-event-opts="{{[['tap',[['call',['$0'],[[['adminList','id',item.$orig.id,'phone']]]]]]]}}" class="admin-item" bindtap="__e"><view class="admin-avatar"><text>{{item.g2}}</text></view><view class="admin-info"><text class="admin-name">{{item.$orig.name}}</text><text class="admin-phone">{{item.$orig.phone}}</text></view><view class="call-btn"><text>拨打</text></view></view></block></view></view></uni-popup></view>