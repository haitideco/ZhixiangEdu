<view class="shop-detail-container"><view class="header-section"><view class="header-bg"></view><view class="header-content"><view data-event-opts="{{[['tap',[['back',['$event']]]]]}}" class="back-btn" bindtap="__e"><text class="back-icon">‹</text></view><text class="header-title">商品详情</text></view></view><view class="main-content"><view class="shop-image"><image src="{{shopDetail.image}}" mode="aspectFill"></image></view><view class="shop-info"><view class="shop-name">{{shopDetail.shopName}}</view><view class="price-row"><view class="price-wrapper"><text class="price-symbol">¥</text><text class="price-value">{{shopDetail.newPrice}}</text></view><view class="inventory">{{"库存: "+shopDetail.inventory}}</view></view><view class="count-row"><text class="count-label">购买数量</text><view class="count-control"><view data-event-opts="{{[['tap',[['decreaseCount',['$event']]]]]}}" class="count-btn" bindtap="__e">-</view><text class="count-value">{{count}}</text><view data-event-opts="{{[['tap',[['increaseCount',['$event']]]]]}}" class="count-btn" bindtap="__e">+</view></view></view></view><view class="detail-section"><view class="section-header"><view class="section-title"><text class="title-text">商品详情</text><view class="title-line"></view></view></view><view class="detail-content"><text class="detail-label">商品描述</text><text class="detail-text">{{shopDetail.description||'暂无描述'}}</text></view></view><view class="comment-section"><view class="section-header"><view class="section-title"><text class="title-text">用户评价</text><view class="title-line"></view></view><text class="comment-count">{{"共"+$root.g0+"条"}}</text></view><view class="comment-list"><block wx:for="{{commentList}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view class="comment-item"><view class="comment-avatar"><image src="{{item.user.image}}" mode="aspectFill"></image></view><view class="comment-content"><view class="comment-header"><text class="comment-name">{{item.user.name}}</text><text class="comment-time">{{item.createTime}}</text></view><view class="comment-rate"><uni-rate vue-id="{{'e31f1a6c-1-'+__i0__}}" readonly="{{true}}" value="{{item.storage}}" size="{{16}}" activeColor="#F97316" bind:__l="__l"></uni-rate></view><text class="comment-text">{{item.content}}</text></view></view></block><block wx:if="{{$root.g1===0}}"><view class="empty-state"><text class="empty-text">暂无评价</text></view></block></view></view></view><view class="bottom-bar"><view class="total-price"><text class="total-label">合计:</text><text class="total-symbol">¥</text><text class="total-value">{{$root.g2}}</text></view><view data-event-opts="{{[['tap',[['buttonClick',['$event']]]]]}}" class="buy-btn" bindtap="__e"><text>立即购买</text></view></view></view>