<view class="student-container"><view class="header-section"><view class="header-bg"></view><view class="header-content"><view class="header-title">课程会员</view><view class="header-subtitle">查看已选课会员列表</view></view></view><view class="student-list"><block wx:for="{{studentList}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view class="student-card"><view class="student-avatar"><image src="{{item.image}}" mode="aspectFill"></image></view><view class="student-info"><view class="student-name">{{item.name}}</view><view class="student-phone">{{item.phone}}</view></view><view class="student-action"><block wx:if="{{item.status==1}}"><view data-event-opts="{{[['tap',[['absence',['$0','$1'],[[['studentList','id',item.id,'id']],[['studentList','id',item.id,'status']]]]]]]}}" class="status-btn arrived" bindtap="__e"> 已到 </view></block><block wx:else><block wx:if="{{item.status==2}}"><view data-event-opts="{{[['tap',[['absence',['$0','$1'],[[['studentList','id',item.id,'id']],[['studentList','id',item.id,'status']]]]]]]}}" class="status-btn absent" bindtap="__e"> 未到 </view></block><block wx:else><view data-event-opts="{{[['tap',[['absence',['$0','$1'],[[['studentList','id',item.id,'id']],[['studentList','id',item.id,'status']]]]]]]}}" class="status-btn pending" bindtap="__e"> 待签到 </view></block></block></view></view></block><block wx:if="{{$root.g0===0}}"><view class="empty-state"><image class="empty-icon" src="/static/img/practice.png"></image><text class="empty-text">暂无选课会员</text></view></block></view></view>