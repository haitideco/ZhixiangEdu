<view class="container"><view class="header"><view class="header-content"><view class="header-title">潮汐健身中心</view><view class="header-subtitle">Tidal Fitness</view></view></view><view class="main-content"><view class="banner"><swiper class="swiper-box" interval="{{3000}}" autoplay="{{true}}" circular="{{true}}" indicator-dots="{{true}}" indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#fff"><block wx:for="{{info}}" wx:for-item="item" wx:for-index="index" wx:key="index"><swiper-item><image class="banner-img" src="{{item}}" mode="aspectFill"></image></swiper-item></block></swiper></view><view class="service-section"><view class="service-grid"><block wx:for="{{services}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view data-event-opts="{{[['tap',[['serviceNav',['$0'],[[['services','',index]]]]]]]}}" class="service-item" bindtap="__e"><view class="service-icon"><image src="{{item.url}}"></image></view><text class="service-text">{{item.text}}</text></view></block></view></view><view class="section-card teacher-section"><view class="section-header"><view class="section-title"><text class="title-text">名师推荐</text><text class="title-line"></text></view><view data-event-opts="{{[['tap',[['commandMore',['$event']]]]]}}" class="section-more" bindtap="__e"><text>更多</text><text class="more-arrow">›</text></view></view><view class="teacher-list"><block wx:for="{{teachers}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="teacher-item"><image class="teacher-avatar" src="{{item.image}}"></image><text class="teacher-name">{{item.name}}</text></view></block></view></view><block wx:if="{{$root.g0>0}}"><view class="notice-section"><view class="notice-icon"><image src="/static/img/notice.png"></image></view><swiper class="notice-swiper" interval="{{3000}}" autoplay="{{true}}" circular="{{true}}" vertical="{{true}}"><block wx:for="{{noticeTitle}}" wx:for-item="item" wx:for-index="index" wx:key="index"><swiper-item><view class="notice-item"><text class="notice-title">{{item.title}}</text><text class="notice-date">{{item.createTime}}</text></view></swiper-item></block></swiper></view></block><view class="section-card contact-section"><view class="section-header"><view class="section-title"><text class="title-text">联系我们</text><text class="title-line"></text></view></view><view class="contact-list"><view class="contact-item"><view class="contact-left"><image class="contact-icon" src="/static/img/map.png"></image><text class="contact-label">地址</text></view><text class="contact-value">{{bussinessInfo.address}}</text></view><view class="contact-item"><view class="contact-left"><image class="contact-icon" src="/static/img/telephone.png"></image><text class="contact-label">电话</text></view><text class="contact-value">{{bussinessInfo.phone}}</text></view><view data-event-opts="{{[['tap',[['open',['$event']]]]]}}" class="contact-item" bindtap="__e"><view class="contact-left"><image class="contact-icon" src="/static/img/wx.png"></image><text class="contact-label">微信</text></view><text class="contact-value">{{bussinessInfo.wx}}</text></view></view></view></view><uni-popup class="vue-ref" vue-id="8dd740cc-1" type="center" data-ref="wx" bind:__l="__l" vue-slots="{{['default']}}"><view class="wx-popup"><view class="wx-title">潮汐健身中心</view><image class="wx-qrcode" src="/static/img/wxerweima.jpg"></image><view class="wx-tip">微信扫码联系客服</view></view></uni-popup></view>