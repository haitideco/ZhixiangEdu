<view class="mine-container"><view class="header-section"><view class="header-bg"></view><view class="header-content"><view class="avatar-wrapper"><image class="avatar" src="{{userDetail.image||defaultImage}}"></image></view><block wx:if="{{user}}"><view data-event-opts="{{[['tap',[['getUser',['$event']]]]]}}" class="user-info" bindtap="__e"><view class="user-name">登录/注册</view><view class="user-desc">立即登录，开启健身之旅</view></view></block><block wx:else><view data-event-opts="{{[['tap',[['updateUser',['$event']]]]]}}" class="user-info" bindtap="__e"><view class="user-name">{{userDetail.name}}</view><view class="user-desc">{{userDetail.type}}</view></view></block></view></view><view class="content-section"><block wx:if="{{userDetail.type=='会员'}}"><view class="stats-card"><block wx:for="{{navArr}}" wx:for-item="item" wx:for-index="__i0__"><view data-event-opts="{{[['tap',[['turn',['$0'],[[['navArr','',__i0__]]]]]]]}}" class="stat-item" bindtap="__e"><view class="stat-icon"><image src="{{item.icon}}"></image></view><view class="stat-info"><view class="stat-count">{{item.count}}</view><view class="stat-label">{{item.text}}</view></view></view></block></view></block><block wx:else><view class="stats-card"><block wx:for="{{navArr1}}" wx:for-item="item" wx:for-index="__i1__"><view class="stat-item"><view class="stat-icon"><image src="{{item.icon}}"></image></view><view class="stat-info"><view class="stat-count">{{item.count}}</view><view class="stat-label">{{item.text}}</view></view></view></block></view></block><view class="service-card"><view class="card-header"><view class="card-title">我的服务</view><view class="card-line"></view></view><view class="service-list"><block wx:for="{{serviceArr}}" wx:for-item="item" wx:for-index="__i2__"><view data-event-opts="{{[['tap',[['turn',['$0'],[[['serviceArr','',__i2__]]]]]]]}}" class="service-item" bindtap="__e"><view class="service-icon-wrapper"><image src="{{item.image}}"></image></view><view class="service-item-text">{{item.text}}</view><view class="service-arrow">›</view></view></block></view></view></view></view>