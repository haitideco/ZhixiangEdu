<view class="notice-container"><view class="header-section"><view class="header-bg"></view><view class="header-content"><view class="header-title">消息通知</view><view class="header-subtitle">查看系统通知消息</view></view></view><view class="notice-list"><block wx:for="{{noticeList}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view class="notice-card"><view class="notice-header"><view class="notice-icon"><image src="/static/img/notice.png"></image></view><view class="notice-title">{{item.title}}</view><view class="notice-time">{{item.createTime}}</view></view><view class="notice-content"><view class="notice-text">{{item.description}}</view></view></view></block><block wx:if="{{$root.g0===0}}"><view class="empty-state"><image class="empty-icon" src="/static/img/notice.png"></image><text class="empty-text">暂无通知消息</text></view></block></view></view>