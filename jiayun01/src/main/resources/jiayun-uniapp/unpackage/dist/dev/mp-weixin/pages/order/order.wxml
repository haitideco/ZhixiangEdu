<view class="order-container"><view class="header-section"><view class="header-bg"></view><view class="header-content"><view class="header-title">我的订单</view><view class="header-subtitle">查看全部订单记录</view></view></view><view class="search-section"><view class="search-box"><uni-icons vue-id="3c50aaa2-1" type="search" size="18" color="#999" bind:__l="__l"></uni-icons><input class="search-input" confirm-type="search" type="text" placeholder="搜索商品名称" data-event-opts="{{[['confirm',[['searchOrder',['$event']]]],['input',[['__set_model',['','searchInput','$event',[]]]]]]}}" value="{{searchInput}}" bindconfirm="__e" bindinput="__e"/><view data-event-opts="{{[['tap',[['searchOrder',['$event']]]]]}}" class="search-btn" bindtap="__e">搜索</view></view></view><view class="order-list"><block wx:for="{{ordersList}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view class="order-card"><view class="order-header"><view class="{{['order-status',(item.status==1)?'status-pending':'',(item.status==2)?'status-completed':'']}}">{{''+(item.status==1?'待付款':'已完成')+''}}</view></view><view data-event-opts="{{[['tap',[['turn',['$0'],[[['ordersList','id',item.id,'id']]]]]]]}}" class="order-content" bindtap="__e"><view class="order-image"><image src="{{item.image}}" mode="aspectFill"></image></view><view class="order-info"><view class="order-name">{{item.shopName}}</view><block wx:if="{{item.shopDescription}}"><view class="order-desc">{{item.shopDescription}}</view></block><view class="order-count">{{"共"+item.shopCount+"件商品"}}</view></view><view class="order-price"><view class="price-label">{{"¥"+item.price}}</view><block wx:if="{{item.shopCount>1}}"><view class="price-count">{{"x"+item.shopCount}}</view></block></view></view><view class="order-footer"><view class="order-total"> 实付款：<text class="total-price">{{"¥"+item.account}}</text></view><view class="order-actions"><view data-event-opts="{{[['tap',[['deleteOrder',['$0'],[[['ordersList','id',item.id,'id']]]]]]]}}" class="action-btn delete-btn" bindtap="__e">删除订单</view><block wx:if="{{item.status==1}}"><view class="action-btn pay-btn">立即付款</view></block><block wx:if="{{item.status==2}}"><view data-event-opts="{{[['tap',[['openPopup',['$0'],[[['ordersList','id',item.id,'shopId']]]]]]]}}" class="action-btn comment-btn" bindtap="__e">发表评论</view></block></view></view></view></block><block wx:if="{{$root.g0===0}}"><view class="empty-state"><image class="empty-icon" src="/static/img/goods.png"></image><text class="empty-text">暂无订单</text></view></block></view><uni-popup class="vue-ref" vue-id="3c50aaa2-2" type="dialog" data-ref="inputDialog" bind:__l="__l" vue-slots="{{['default']}}"><view class="comment-popup"><view class="popup-header"><text class="popup-title">发表评论</text><text data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" class="popup-close" bindtap="__e">×</text></view><view class="popup-content"><view class="form-item"><text class="form-label">评论内容</text><textarea class="form-textarea" placeholder="请输入评论内容" maxlength="200" data-event-opts="{{[['input',[['__set_model',['$0','content','$event',[]],['baseFormData']]]]]}}" value="{{baseFormData.content}}" bindinput="__e"></textarea></view><view class="form-item"><text class="form-label">商品评分</text><view class="rate-wrapper"><uni-rate bind:input="__e" vue-id="{{('3c50aaa2-3')+','+('3c50aaa2-2')}}" size="{{20}}" activeColor="#4facfe" value="{{baseFormData.storage}}" data-event-opts="{{[['^input',[['__set_model',['$0','storage','$event',[]],['baseFormData']]]]]}}" bind:__l="__l"></uni-rate><text class="rate-text">{{(baseFormData.storage||0)+"分"}}</text></view></view></view><view class="popup-footer"><view data-event-opts="{{[['tap',[['e1',['$event']]]]]}}" class="cancel-btn" bindtap="__e">取消</view><view data-event-opts="{{[['tap',[['dialogInputConfirm',['$event']]]]]}}" class="confirm-btn" bindtap="__e">提交评论</view></view></view></uni-popup></view>