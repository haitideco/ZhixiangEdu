<view class="activity-container"><view class="header-section"><view class="header-bg"></view><view class="header-content"><view class="header-title">限时活动</view><view class="header-subtitle">超值优惠，不容错过</view></view></view><view class="activity-list"><block wx:for="{{activityList}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view class="activity-card"><view class="activity-image"><image src="{{item.image}}" mode="aspectFill"></image><block wx:if="{{item.type}}"><view class="activity-badge">{{item.type}}</view></block></view><view class="activity-info"><view class="activity-name">{{item.activityName}}</view><block wx:if="{{item.description}}"><view class="activity-desc">{{item.description}}</view></block><view class="activity-footer"><view class="price-wrapper"><view class="current-price"><text class="price-label">¥</text><text class="price-value">{{item.nowPrice}}</text></view><block wx:if="{{item.oldPrice}}"><view class="original-price"><text>{{"¥"+item.oldPrice}}</text></view></block></view><view class="buy-btn">立即抢购</view></view></view></view></block><block wx:if="{{$root.g0===0}}"><view class="empty-state"><image class="empty-icon" src="/static/img/activity.png"></image><text class="empty-text">暂无活动</text></view></block></view></view>