<view class="command-container"><view class="header-section"><view class="header-bg"></view><view class="header-content"><view class="header-title">名师推荐</view><view class="header-subtitle">专业教练，助力成长</view></view></view><view class="teacher-list"><block wx:for="{{teacherList}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view class="teacher-card"><view class="teacher-avatar"><image src="{{item.image}}" mode="aspectFill"></image></view><view class="teacher-info"><view class="teacher-name">{{item.name}}</view><view class="teacher-tags"><block wx:if="{{item.sex}}"><text class="tag">{{item.sex}}</text></block><block wx:if="{{item.specialty}}"><text class="tag">{{item.specialty}}</text></block></view><block wx:if="{{item.description}}"><view class="teacher-desc">{{item.description}}</view></block></view><view class="teacher-arrow">›</view></view></block><block wx:if="{{$root.g0===0}}"><view class="empty-state"><image class="empty-icon" src="/static/img/teacher1.png"></image><text class="empty-text">暂无老师</text></view></block></view></view>