<view class="course-container"><block wx:if="{{userType=='会员'}}"><view class="member-view"><view class="header-section"><view class="header-bg"></view><view class="header-content"><view class="header-title">预约课程</view><view class="header-subtitle">选择适合你的课程</view></view></view><view class="tabs-section"><scroll-view class="tabs-scroll" scroll-x="{{true}}"><view class="tabs-wrapper"><block wx:for="{{items}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view data-event-opts="{{[['tap',[['onClickItem',[['o',['currentIndex',index]]]]]]]}}" class="{{['tab-item',(current===index)?'active':'']}}" bindtap="__e">{{''+item+''}}</view></block></view></scroll-view></view><view class="course-list"><block wx:for="{{leagueClass}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view class="course-card"><view class="course-image"><image src="/static/img/practice.png" mode="aspectFill"></image></view><view class="course-info"><view class="course-name">{{item.name}}</view><view class="course-tags"><block wx:for="{{item.tags}}" wx:for-item="tag" wx:for-index="index" wx:key="index"><text class="tag">{{tag}}</text></block></view><block wx:if="{{item.description}}"><view class="course-desc">{{item.description}}</view></block><view class="course-footer"><block wx:if="{{item.price}}"><view class="course-price"><text class="price-label">¥</text><text class="price-value">{{item.price}}</text></view></block><view data-event-opts="{{[['tap',[['chooseClasses',['$0'],[[['leagueClass','id',item.id]]]]]]]}}" class="choose-btn" bindtap="__e"> 立即预约 </view></view></view></view></block><block wx:if="{{$root.g0===0}}"><view class="empty-state"><image class="empty-icon" src="/static/img/practice.png"></image><text class="empty-text">暂无课程</text></view></block></view></view></block><block wx:else><view class="teacher-view"><view class="header-section"><view class="header-bg"></view><view class="header-content"><view class="header-title">我的课程</view><view class="header-subtitle">管理已开设的课程</view></view></view><view class="teacher-actions"><view data-event-opts="{{[['tap',[['openDialog']]]]}}" class="add-btn" bindtap="__e"><text class="add-icon">+</text><text class="add-text">新建课程</text></view></view><view class="class-list"><block wx:for="{{classesList}}" wx:for-item="item" wx:for-index="__i1__" wx:key="id"><view class="class-card"><view class="class-time"><view class="time-icon"><image src="/static/img/activity.png"></image></view><view class="time-text">{{item.endTime}}</view></view><view class="class-content"><view class="class-image"><image src="{{item.imgs}}" mode="aspectFill"></image></view><view class="class-info"><view class="class-name">{{item.name}}</view><view class="class-room"><image class="room-icon" src="/static/img/map.png"></image><text>{{item.roomName}}</text></view></view><view data-event-opts="{{[['tap',[['navToStudentList',['$0'],[[['classesList','id',item.id,'id']]]]]]]}}" class="class-action" bindtap="__e"><text>查看会员</text></view></view></view></block><block wx:if="{{$root.g1===0}}"><view class="empty-state"><image class="empty-icon" src="/static/img/practice.png"></image><text class="empty-text">暂无课程</text></view></block></view></view></block><uni-popup class="vue-ref" vue-id="45564bd8-1" type="dialog" data-ref="inputDialog" bind:__l="__l" vue-slots="{{['default']}}"><view class="dialog-container"><view class="dialog-header"><view class="header-left"><view class="header-icon"><image src="/static/img/practice.png"></image></view><text class="dialog-title">新建课程</text></view><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" class="dialog-close" bindtap="__e"><text>×</text></view></view><scroll-view class="dialog-content" scroll-y="{{true}}"><view class="form-section"><view class="section-title">基本信息</view><view class="form-item"><text class="form-label">课程名称</text><input class="form-input" placeholder="请输入课程名称" data-event-opts="{{[['input',[['__set_model',['$0','name','$event',[]],['baseFormData']]]]]}}" value="{{baseFormData.name}}" bindinput="__e"/></view><view class="form-row"><view class="form-item half"><text class="form-label">课程价格</text><input class="form-input" placeholder="请输入价格" type="number" data-event-opts="{{[['input',[['__set_model',['$0','price','$event',[]],['baseFormData']]]]]}}" value="{{baseFormData.price}}" bindinput="__e"/></view><view class="form-item half"><text class="form-label">上限人数</text><input class="form-input" placeholder="请输入人数" type="number" data-event-opts="{{[['input',[['__set_model',['$0','pmax','$event',[]],['baseFormData']]]]]}}" value="{{baseFormData.pmax}}" bindinput="__e"/></view></view></view><view class="form-section"><view class="section-title">课程标签</view><view class="form-item"><view class="tags-select"><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view data-event-opts="{{[['tap',[['toggleTag',['$0'],[[['tagsList','',index,'value']]]]]]]}}" class="{{['tag-option',(item.g2)?'selected':'']}}" bindtap="__e"><block wx:if="{{item.g3}}"><text class="tag-check">✓</text></block>{{''+item.$orig.text+''}}</view></block></view></view></view><view class="form-section"><view class="section-title">时间地点</view><view class="form-item"><text class="form-label">教室名称</text><picker mode="selector" range="{{roomList}}" range-key="text" data-event-opts="{{[['change',[['onRoomChange',['$event']]]]]}}" bindchange="__e"><view class="form-picker"><block wx:if="{{baseFormData.roomName}}"><text>{{baseFormData.roomName}}</text></block><block wx:else><text class="placeholder">请选择教室</text></block><text class="picker-arrow">›</text></view></picker></view><view class="form-row"><view class="form-item half"><text class="form-label">开课时间</text><picker mode="multiSelector" range="{{dateTimeRange}}" value="{{startTimeValue}}" data-event-opts="{{[['change',[['onStartTimeChange',['$event']]]],['columnchange',[['onColumnChange',['$event']]]]]}}" bindchange="__e" bindcolumnchange="__e"><view class="form-picker"><block wx:if="{{baseFormData.startTime}}"><text class="time-text">{{$root.g4}}</text></block><block wx:else><text class="placeholder">选择时间</text></block><text class="picker-arrow">›</text></view></picker></view><view class="form-item half"><text class="form-label">结束时间</text><picker mode="multiSelector" range="{{dateTimeRange}}" value="{{endTimeValue}}" data-event-opts="{{[['change',[['onEndTimeChange',['$event']]]],['columnchange',[['onColumnChange',['$event']]]]]}}" bindchange="__e" bindcolumnchange="__e"><view class="form-picker"><block wx:if="{{baseFormData.endTime}}"><text class="time-text">{{$root.g5}}</text></block><block wx:else><text class="placeholder">选择时间</text></block><text class="picker-arrow">›</text></view></picker></view></view></view><view class="form-section"><view class="section-title">课程封面</view><view class="form-item"><view data-event-opts="{{[['tap',[['upload']]]]}}" class="upload-area" bindtap="__e"><block wx:if="{{imageUrl}}"><image class="preview-image" src="{{imageUrl}}"></image></block><block wx:else><view class="upload-placeholder"><text class="upload-icon">+</text><text class="upload-text">上传课程封面</text></view></block></view></view></view><view class="form-section"><view class="section-title">课程描述</view><view class="form-item"><textarea class="form-textarea" placeholder="请输入课程描述（选填）" maxlength="200" data-event-opts="{{[['input',[['__set_model',['$0','description','$event',[]],['baseFormData']]]]]}}" value="{{baseFormData.description}}" bindinput="__e"></textarea></view></view></scroll-view><view class="dialog-footer"><view data-event-opts="{{[['tap',[['e1',['$event']]]]]}}" class="cancel-btn" bindtap="__e">取消</view><view data-event-opts="{{[['tap',[['dialogInputConfirm',['$event']]]]]}}" class="confirm-btn" bindtap="__e">创建课程</view></view></view></uni-popup></view>