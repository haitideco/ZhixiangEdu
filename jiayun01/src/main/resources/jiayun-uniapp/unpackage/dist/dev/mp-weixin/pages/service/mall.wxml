<view class="mall-container"><view class="header-section"><view class="header-bg"></view><view class="header-content"><view class="header-title">潮汐商城</view><view class="header-subtitle">精选好物，品质生活</view></view></view><view class="quick-entry"><block wx:for="{{services}}" wx:for-item="item" wx:for-index="__i0__" wx:key="text"><view data-event-opts="{{[['tap',[['navTo',['$0'],[[['services','text',item.text,'url']]]]]]]}}" class="entry-item" bindtap="__e"><view class="entry-icon"><image src="{{item.imgSrc}}"></image></view><text class="entry-text">{{item.text}}</text></view></block></view><view class="mall-content"><view class="category-nav"><scroll-view class="category-scroll" scroll-y="{{true}}"><block wx:for="{{categoryList}}" wx:for-item="item" wx:for-index="__i1__" wx:key="id"><view data-event-opts="{{[['tap',[['initShop',['$0'],[[['categoryList','id',item.id,'id']]]]]]]}}" class="{{['category-item',(currentCategory===item.id)?'active':'']}}" bindtap="__e"><text>{{item.name}}</text></view></block></scroll-view></view><view class="product-list"><block wx:for="{{shopList}}" wx:for-item="item" wx:for-index="__i2__" wx:key="id"><view data-event-opts="{{[['tap',[['shopDetail',['$0'],[[['shopList','id',item.id]]]]]]]}}" class="product-item" bindtap="__e"><view class="product-image"><image src="{{item.image}}" mode="aspectFill"></image><block wx:if="{{item.status==0}}"><view class="product-status">已停售</view></block></view><view class="product-info"><view class="product-name">{{item.shopName}}</view><view class="product-desc">{{item.description}}</view><view class="product-footer"><view class="price-box"><view class="current-price"><text class="price-label">¥</text><text class="price-value">{{item.newPrice}}</text></view><block wx:if="{{item.oldPrice}}"><view class="original-price"><text>{{"¥"+item.oldPrice}}</text></view></block></view><block wx:if="{{item.status==1}}"><view class="buy-btn">购买</view></block><block wx:else><view class="disabled-btn">停售</view></block></view></view></view></block><block wx:if="{{$root.g0===0}}"><view class="empty-state"><image class="empty-icon" src="/static/img/goods.png"></image><text class="empty-text">暂无商品</text></view></block></view></view></view>