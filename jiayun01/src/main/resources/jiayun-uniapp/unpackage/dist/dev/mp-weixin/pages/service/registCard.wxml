<view class="card-container"><view class="header-section"><view class="header-bg"></view><view class="header-content"><view class="header-title">会员办卡</view><view class="header-subtitle">选择适合你的会员卡</view></view></view><view class="tabs-section"><scroll-view class="tabs-scroll" scroll-x="{{true}}"><view class="tabs-wrapper"><block wx:for="{{items}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view data-event-opts="{{[['tap',[['onClickItem',[['o',['currentIndex',index]]]]]]]}}" class="{{['tab-item',(current===index)?'active':'']}}" bindtap="__e">{{''+item+''}}</view></block></view></scroll-view></view><view class="card-list"><block wx:for="{{cardAll}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view data-event-opts="{{[['tap',[['cardDetail',['$0'],[[['cardAll','id',item.id]]]]]]]}}" class="card-item" bindtap="__e"><view class="card-image"><image src="{{item.image}}" mode="aspectFill"></image><view class="card-badge">{{item.type}}</view></view><view class="card-info"><view class="card-name">{{item.name}}</view><block wx:if="{{item.description}}"><view class="card-desc">{{item.description}}</view></block><view class="card-footer"><view class="card-price"><text class="price-label">¥</text><text class="price-value">{{item.price}}</text></view><view class="card-btn">立即办理</view></view></view></view></block><block wx:if="{{$root.g0===0}}"><view class="empty-state"><image class="empty-icon" src="/static/img/card.png"></image><text class="empty-text">暂无会员卡</text></view></block></view></view>